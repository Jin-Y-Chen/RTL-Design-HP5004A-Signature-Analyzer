*.jou
*.log
*.str
*.wdb
*.pb
*.xml
*.html
*.ltx
*.xpr.cache/
*.runs/
*.sim/
*.ip_user_files/
*.hw/
*.webtalk/
*.cache/
*.data/
*.tmp
*.backup
*.restore
*.xsim/
*.vivado.log
*.vivado.jou
*.vivado.wdb
*.vitis*

# Ignore project files you do not want tracked
hp5004a-signature-analyzer/hp5004a-signature-analyzer.xpr
hp5004a-signature-analyzer/hp5004a-signature-analyzer.srcs/utils_1/imports/synth_1/hp5004a.dcp

# Simulation output
*.vcd
*.wlf
*.asdb

# OS generated files
Thumbs.db
Desktop.ini
.DS_Store

# User-specific files
*.swp
*.swo
*.bak
*.user

# Only track source and documentation files
!*.vhd
!*.vhdl
!*.v
!*.sv
!*.xdc
!*.tcl
!*.xpr
